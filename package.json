{
  "name": "dof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:data": "node scripts/check-data-constitution.mjs",
    "lint": "eslint .",
    "db:grants": "tsx db/apply-grants.ts",
    "test": "npm run test:unit && npm run test:ui && npm run test:integration",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "tokens:generate": "node scripts/generate-tokens.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "build:storybook": "storybook build --output-dir storybook-static",
    "test:e2e-ui": "playwright test",
    "check:operations": "node scripts/check-operations.mjs",
    "check:identity": "node scripts/check-identity.mjs"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@vercel/blob": "^2.6.1",
    "@vueuse/core": "^13.9.0",
    "hash-wasm": "^4.12.0",
    "nuxt": "^3.17.0",
    "pg": "^8.13.0",
    "reka-ui": "^2.10.1",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@iconify-json/lucide": "^1.2.116",
    "@playwright/test": "^1.61.1",
    "@storybook/vue3-vite": "^9.1.20",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.11",
    "embedded-postgres": "^17.2.0-beta.15",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "http-server": "^14.1.1",
    "storybook": "^9.1.20",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.0",
    "vue-tsc": "^3.3.6",
    "yaml": "^2.9.0"
  }
}
