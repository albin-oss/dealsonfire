# PostgreSQL connection (Neon-class on Vercel; local for development)
NUXT_DATABASE_URL=postgres://user:pass@localhost:5432/dof

# Secret required by internal task routes (Vercel cron calls /api/internal/outbox-dispatch)
NUXT_CRON_SECRET=change-me

# Identity integration point. 'dev' accepts the x-dof-user-id header (NEVER in production).
# 'session' is the Identity-domain session adapter and fails closed until Identity lands.
NUXT_IDENTITY_MODE=dev

# Integration tests: point at an existing PostgreSQL to skip embedded-postgres bootstrap
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/dof_test
